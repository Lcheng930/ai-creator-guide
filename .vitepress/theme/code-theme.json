{
  "name": "custom-dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0e0e12",
    "editor.foreground": "#cccccc"
  },
  "tokenColors": [
    {
      "name": "Base — 80% 白色",
      "scope": ["source"],
      "settings": { "foreground": "#cccccc" }
    },
    {
      "name": "关键字 — 亮紫色",
      "scope": [
        "keyword", "keyword.control",
        "storage.type", "storage.modifier"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "字符串（双引号内容）— 青蓝色",
      "scope": [
        "string", "string.quoted", "string.template",
        "string.regexp"
      ],
      "settings": { "foreground": "#38bdf8" }
    },
    {
      "name": "注释/中文 — 粉紫色",
      "scope": ["comment", "comment.block", "comment.line"],
      "settings": {
        "foreground": "#d4a0ff",
        "fontStyle": "italic"
      }
    }
  ]
}
